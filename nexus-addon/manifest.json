{
  "manifest_version": 2,
  "name": "Nexus Accounting",
  "version": "1.3.1",
  "description": "Tracks survey and pirate raid data from Nexus Legacy — aggregates resources collected and ships lost over time with daily and hourly breakdowns.",
  "author": "Verrok",
  "homepage_url": "https://github.com/Verroq/NexusAccounting",
  "permissions": [
    "cookies",
    "storage",
    "alarms",
    "downloads",
    "webRequest",
    "webRequestBlocking",
    "https://s0.nexuslegacy.space/*",
    "https://nexuslegacy.space/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "browser_action": {
    "default_title": "Nexus Accounting",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": ["dashboard.html", "simulator.html"],
  "browser_specific_settings": {
    "gecko": {
      "id": "nexus-accounting@verrok",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}
