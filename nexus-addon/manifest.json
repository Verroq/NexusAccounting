{
  "manifest_version": 3,
  "name": "Nexus Accounting",
  "version": "1.5.6",
  "description": "Tracks Nexus Legacy survey and pirate data — aggregates resources collected and ships lost, with daily and hourly breakdowns.",
  "author": "Verrok",
  "homepage_url": "https://github.com/Verroq/NexusAccounting",
  "permissions": [
    "cookies",
    "storage",
    "alarms",
    "downloads",
    "webRequest"
  ],
  "host_permissions": [
    "*://*.nexuslegacy.space/*",
    "*://nexuslegacy.space/*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ]
  },
  "action": {
    "default_title": "Nexus Accounting",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://s0.nexuslegacy.space/*"],
      "js": ["sidebar-inject.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "dashboard.html",
        "simulator.html"
      ],
      "matches": [
        "https://s0.nexuslegacy.space/*",
        "https://nexuslegacy.space/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "nexus-accounting@verrok",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    }
  }
}
